# ========================
# DATABASE CONFIGURATION
# ========================

# Option 1: Local PostgreSQL (default)
# Install: brew install postgresql (macOS) or apt install postgresql (Linux)
DB_PROVIDER=local
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=jobmailer

# Option 2: Supabase (recommended cloud option)
# Sign up: https://supabase.com (Free tier: 500MB)
# Copy the connection string from Supabase > Project Settings > Database
# DATABASE_URL=postgresql+psycopg2://[user]:[password]@[host]:[port]/[database]

# Option 3: Railway.app
# Sign up: https://railway.app (Free tier: $5/month credit)
# Get URL from Dashboard > Postgres > Connect > Postgres URI

# Option 4: Render
# Sign up: https://render.com (Free tier: 90 days)
# Get URL from Databases section

# Option 5: PlanetScale (MySQL - compatible with SQLAlchemy)
# Sign up: https://planetscale.com (Free tier: 5GB)
# DATABASE_URL=mysql+pymysql://[user]:[password]@[host]:[port]/[database]

# Groq API Key
GROQ_API_KEY=your_groq_api_key_here

# Gmail Configuration
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# Resume File ID (Google Drive)
RESUME_FILE_ID=your_resume_file_id

# Streak Configuration
STREAK_WHATSAPP_TO=your_whatsapp_number
# Leave empty unless you really want automated streak emails.
STREAK_EMAIL_TO=

# WhatsApp Webhook
WHATSAPP_WEBHOOK_URL=your_webhook_url

# Sender Configuration
SENDER_NAME=Your Name

# Deliverability controls
# Keep cold outreach slow and one-to-one. Set ATTACH_COVER_LETTER=true only if
# you really want a second PDF on first contact; resume-only is safer.
ATTACH_COVER_LETTER=false
INCLUDE_SIGNATURE_LINKS=false
ALLOW_SELF_APPLICATION_TESTS=false
MAX_APPLICATION_SENDS_PER_24H=25
MIN_SECONDS_BETWEEN_APPLICATION_SENDS=120
MIN_DAYS_BETWEEN_SAME_RECIPIENT=3
